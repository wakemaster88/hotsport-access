# /etc/hotsport-hub/hub.env  (Mode 0640, Eigentümer: root:hotsport)

HOTSPORT_HUB_HOST=0.0.0.0
HOTSPORT_HUB_PORT=8000

HOTSPORT_HUB_DATA_DIR=/var/lib/hotsport-hub
HOTSPORT_HUB_RELEASES_DIR=/var/lib/hotsport-hub/releases
HOTSPORT_HUB_DB=/var/lib/hotsport-hub/hub.sqlite3

# Basic-Auth fürs Dashboard (Admin-Endpunkte). Leer lassen = ohne Auth (nur LAN!)
HOTSPORT_HUB_DASHBOARD_USER=admin
HOTSPORT_HUB_DASHBOARD_PASSWORD=bitte-aendern

# Bearer-Token, das die Pis bei Heartbeat/Desired-Calls mitschicken müssen.
HOTSPORT_HUB_PI_TOKEN=bitte-langes-zufaelliges-token-eintragen

# Sekunden bis ein Pi als offline gilt
HOTSPORT_HUB_OFFLINE_THRESHOLD_SECONDS=30
